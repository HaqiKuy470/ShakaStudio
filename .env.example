# Copy file ini jadi ".env.local" dan isi nilainya. Jangan commit .env.local!

# --- Jembatan verifikasi member (dipakai app/api/verify) ---
# URL HTTP server milik bot yang nerima callback verifikasi
# (lihat BotDc/member-verification.js -> startVerifyServer).
# Bot harus bisa diakses publik dari server ini, misal lewat domain/subdomain
# hosting bot atau tunnel (ngrok, dsb).
BOT_VERIFY_CALLBACK_URL=https://bot.shakastudio.net/api/verify-callback

# Harus SAMA PERSIS dengan MEMBER_VERIFY_CALLBACK_SECRET di BotDc/.env
BOT_VERIFY_CALLBACK_SECRET=ganti_dengan_secret_lain_yang_beda_dan_rahasia

# --- Webhook "server baru pasang bot" (dipakai app/api/discord/webhook) ---
# Harus SAMA PERSIS dengan VERIFY_WEBHOOK_SECRET di BotDc/.env.
# Kosongkan (di kedua sisi) kalau tidak butuh proteksi ini.
DISCORD_WEBHOOK_SECRET=ganti_dengan_secret_acak_sama_dengan_bot

# (Opsional) URL webhook channel Discord admin, dipakai buat notifikasi
# otomatis tiap ada server baru invite bot. Kosongkan kalau tidak perlu.
DISCORD_ADMIN_NOTIFY_WEBHOOK_URL=

# --- Daftar server terverifikasi (dipakai app/api/discord/verified-guilds) ---
# Guild ID dipisah koma. Bot polling endpoint ini tiap VERIFY_POLL_INTERVAL_MS
# untuk tahu server mana yang boleh pakai fitur Join-to-Create.
VERIFIED_GUILD_IDS=
